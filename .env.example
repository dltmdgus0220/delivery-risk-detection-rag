# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=review_db
DATABASE_URL=postgresql://admin:password@postgres:5432/review_db

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Cohere (리랭킹)
COHERE_API_KEY=your-cohere-api-key

# 파이프라인 설정
# CHUNKER_MODE: "single"(기본) 또는 "aspect"(LLM 기반 측면 분리)
CHUNKER_MODE=single
# EMBEDDING_MODEL: 평가 결과 intfloat/multilingual-e5-large 선정 (Stage 5)
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# RERANKER: 평가 결과 albert-kor 선정 (Stage 6) | cross-encoder | cross-encoder-mmarco | mmr | cohere
RERANKER=albert-kor
