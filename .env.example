# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=review_db
DATABASE_URL=postgresql://admin:password@postgres:5432/review_db

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Cohere (리랭킹)
COHERE_API_KEY=your-cohere-api-key

# 파이프라인 설정
# CHUNKER_MODE: "single"(기본) 또는 "aspect"(LLM 기반 측면 분리)
CHUNKER_MODE=single
# EMBEDDING_MODEL: "BAAI/bge-m3"(기본) | "intfloat/multilingual-e5-large" | "text-embedding-3-small"
EMBEDDING_MODEL=BAAI/bge-m3
